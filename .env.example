# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ragdb
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_MAX=20

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-256-bit-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
API_BASE_URL=http://localhost:8000

# ── SendGrid ──────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourapp.com
EMAIL_FROM_NAME=RAG System

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rag-docs
MINIO_SECURE=false

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── OpenRouter (LLM) ─────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemma-2-9b-it
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# ── OpenAI (Embeddings) ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
EMBED_MODEL=text-embedding-3-small
EMBED_DIMENSIONS=1536

# ── Jina (Reranker) ──────────────────────────────────────────────────────────
JINA_API_KEY=jina_xxxxxxxxxxxxxxxxxxxx
JINA_RERANKER_MODEL=jina-reranker-v2-base-multilingual
JINA_RERANKER_TOP_N=5

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_DAY=1000

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
LOG_LEVEL=INFO
